<!DOCTYPE html>
<html dir="rtl" lang="ar">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>عرض خدمات — Advanced Panel Solutions | وكالة سحاب</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --steel: #1C2536;
    --slate: #2D3A4A;
    --blue: #1A56DB;
    --cyan: #38BDF8;
    --silver: #94A3B8;
    --light: #F1F5F9;
    --border: #E2E8F0;
    --white: #ffffff;
    --gold: #F59E0B;
  }

  body {
    font-family: 'Cairo', sans-serif;
    background: #e8ecf0;
    color: #1e293b;
    font-size: 14px;
    line-height: 1.7;
  }

  .page {
    width: 794px;
    margin: 24px auto;
    background: var(--white);
    box-shadow: 0 4px 24px rgba(0,0,0,0.12);
    border-radius: 2px;
    overflow: hidden;
  }

  /* ===== COVER ===== */
  .cover {
    background: var(--steel);
    min-height: 1120px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .cover-bg-lines {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image:
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 60px,
        rgba(255,255,255,0.02) 60px,
        rgba(255,255,255,0.02) 61px
      ),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 60px,
        rgba(255,255,255,0.02) 60px,
        rgba(255,255,255,0.02) 61px
      );
  }

  .cover-accent {
    position: absolute;
    bottom: 0; left: 0;
    width: 100%; height: 6px;
    background: linear-gradient(90deg, var(--blue), var(--cyan));
  }

  .cover-diagonal {
    position: absolute;
    top: 0; left: 0;
    width: 340px; height: 100%;
    background: rgba(26,86,219,0.06);
    clip-path: polygon(0 0, 75% 0, 100% 100%, 0 100%);
  }

  .cover-header {
    padding: 44px 52px 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    position: relative;
    z-index: 2;
  }

  .logo-box { display: flex; flex-direction: column; align-items: flex-end; }
  .logo-text { font-size: 28px; font-weight: 900; color: var(--white); letter-spacing: 3px; }
  .logo-sub { font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 1px; margin-top: 2px; }

  .contact-info { text-align: left; color: rgba(255,255,255,0.45); font-size: 11px; line-height: 2; }

  .cover-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 52px;
    position: relative;
    z-index: 2;
  }

  .for-label {
    font-size: 11px;
    color: var(--cyan);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-weight: 600;
  }

  .client-name-en {
    font-size: 42px;
    font-weight: 900;
    color: var(--white);
    line-height: 1.15;
    margin-bottom: 6px;
    letter-spacing: -0.5px;
  }

  .client-name-ar {
    font-size: 16px;
    color: rgba(255,255,255,0.45);
    margin-bottom: 36px;
  }

  .cover-divider {
    width: 50px; height: 3px;
    background: linear-gradient(90deg, var(--blue), var(--cyan));
    margin-bottom: 36px;
  }

  .services-pills { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 52px; }

  .pill {
    background: rgba(26,86,219,0.2);
    border: 1px solid rgba(56,189,248,0.3);
    color: var(--cyan);
    padding: 8px 20px;
    border-radius: 2px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .cover-meta {
    display: flex;
    gap: 32px;
    margin-top: auto;
  }

  .meta-item .meta-label { font-size: 10px; color: rgba(255,255,255,0.3); letter-spacing: 1px; margin-bottom: 2px; }
  .meta-item .meta-val { font-size: 12px; color: rgba(255,255,255,0.6); font-weight: 600; }

  .cover-footer {
    padding: 24px 52px;
    background: rgba(0,0,0,0.3);
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .cover-footer span { font-size: 11px; color: rgba(255,255,255,0.3); }

  .valid-badge {
    background: rgba(26,86,219,0.25);
    border: 1px solid rgba(56,189,248,0.3);
    color: var(--cyan);
    padding: 6px 16px;
    border-radius: 2px;
    font-size: 11px;
  }

  /* ===== PAGE HEADER ===== */
  .page-header {
    background: var(--steel);
    padding: 20px 52px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid var(--blue);
  }

  .page-header .logo-small { font-size: 17px; font-weight: 900; color: var(--white); letter-spacing: 2px; }
  .page-header .page-info { font-size: 11px; color: rgba(255,255,255,0.4); }

  /* ===== CONTENT ===== */
  .content { padding: 44px 52px; }

  .section-label {
    font-size: 10px; font-weight: 700; color: var(--blue);
    letter-spacing: 3px; text-transform: uppercase; margin-bottom: 6px;
  }

  .section-title { font-size: 22px; font-weight: 900; color: var(--steel); margin-bottom: 6px; }

  .section-line { width: 36px; height: 3px; background: linear-gradient(90deg, var(--blue), var(--cyan)); margin-bottom: 24px; }

  /* ===== BRIEF GRID ===== */
  .brief-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 32px; }

  .brief-item {
    background: var(--light);
    border: 1px solid var(--border);
    border-right: 3px solid var(--blue);
    padding: 14px 18px; border-radius: 2px;
  }

  .brief-item .label { font-size: 10px; color: var(--silver); letter-spacing: 1.5px; font-weight: 700; margin-bottom: 4px; }
  .brief-item .value { font-size: 13.5px; font-weight: 700; color: var(--steel); }

  /* ===== INTRO BOX ===== */
  .intro-box {
    background: var(--steel);
    color: rgba(255,255,255,0.8);
    padding: 20px 24px;
    border-radius: 2px;
    font-size: 13px;
    line-height: 1.9;
    margin-bottom: 32px;
    border-right: 4px solid var(--cyan);
  }

  /* ===== TARGET ===== */
  .target-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 32px; }

  .target-item {
    display: flex; align-items: center; gap: 10px;
    background: var(--light); border: 1px solid var(--border);
    padding: 11px 16px; border-radius: 2px;
    font-size: 12.5px; color: #374151;
  }

  .target-item::before { content: '◆'; color: var(--blue); font-size: 8px; flex-shrink: 0; }

  /* ===== VISUAL DIRECTION ===== */
  .visual-dir { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 24px; }

  .vd-item {
    background: var(--steel);
    text-align: center; padding: 18px 10px;
    border-radius: 2px; border-bottom: 3px solid var(--blue);
  }

  .vd-ar { font-size: 14px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .vd-en { font-size: 10px; color: rgba(255,255,255,0.4); letter-spacing: 1px; }

  .colors-row { display: flex; gap: 10px; margin-bottom: 32px; align-items: center; }
  .color-swatch { width: 36px; height: 36px; border-radius: 2px; flex-shrink: 0; }
  .color-label { font-size: 11px; color: var(--silver); }

  /* ===== SCOPE ===== */
  .scope-block { margin-bottom: 28px; }

  .scope-block-title {
    display: flex; align-items: center; gap: 12px;
    background: var(--steel); color: var(--white);
    padding: 13px 20px; font-size: 13.5px; font-weight: 700; border-radius: 2px 2px 0 0;
  }

  .scope-block-title .num {
    background: var(--blue); color: white;
    width: 24px; height: 24px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 900; flex-shrink: 0;
  }

  .scope-block-title .en-tag { font-size: 11px; color: var(--cyan); margin-right: auto; font-weight: 400; }

  .scope-items { border: 1px solid var(--border); border-top: none; border-radius: 0 0 2px 2px; overflow: hidden; }

  .scope-item {
    display: flex; align-items: center; gap: 12px;
    padding: 10px 20px; border-bottom: 1px solid var(--border);
    font-size: 12.5px; color: #374151;
  }

  .scope-item:last-child { border-bottom: none; }
  .scope-item:nth-child(even) { background: var(--light); }
  .scope-item::before { content: '✓'; color: var(--blue); font-weight: 900; flex-shrink: 0; }

  /* ===== DELIVERABLES ===== */
  .deliverables-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 14px; margin-bottom: 32px; }

  .deliv-card { border: 1px solid var(--border); border-radius: 2px; overflow: hidden; }

  .deliv-head {
    background: var(--steel); padding: 12px 16px;
    font-size: 12px; font-weight: 700; color: var(--white);
    border-bottom: 2px solid var(--blue);
  }

  .deliv-body { padding: 12px 16px; background: var(--light); }

  .deliv-body li {
    font-size: 11.5px; color: #374151;
    padding: 4px 0; border-bottom: 1px solid var(--border);
    padding-right: 12px; position: relative;
  }

  .deliv-body li:last-child { border-bottom: none; }

  .deliv-body li::before {
    content: '—'; position: absolute; right: 0;
    color: var(--blue); font-size: 10px;
  }

  /* ===== PRICING ===== */
  .pricing-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; overflow: hidden; border-radius: 2px; }

  .pricing-table thead tr { background: var(--steel); color: var(--white); }

  .pricing-table th { padding: 14px 20px; text-align: right; font-size: 12px; font-weight: 700; }

  .pricing-table td { padding: 14px 20px; font-size: 13px; border-bottom: 1px solid var(--border); color: #374151; }

  .pricing-table tr:nth-child(even) td { background: var(--light); }

  .pricing-table tr.total td {
    background: var(--steel); color: var(--white);
    font-weight: 900; font-size: 15px; border-bottom: none;
  }

  .price-val { font-weight: 700; color: var(--steel); }
  .price-val.big { color: var(--blue); font-size: 16px; }

  /* ===== PAYMENT SCHEDULE ===== */
  .payment-steps { display: flex; margin-bottom: 32px; border: 1px solid var(--border); border-radius: 2px; overflow: hidden; }

  .payment-step { flex: 1; text-align: center; padding: 20px 12px; border-left: 1px solid var(--border); }
  .payment-step:last-child { border-left: none; }

  .payment-step .ps-pct { font-size: 26px; font-weight: 900; color: var(--blue); }
  .payment-step .ps-amount { font-size: 13px; font-weight: 700; color: var(--steel); margin: 4px 0; }
  .payment-step .ps-when { font-size: 11px; color: var(--silver); line-height: 1.5; }

  /* ===== TIMELINE ===== */
  .timeline { display: flex; margin-bottom: 32px; }

  .tl-item { flex: 1; text-align: center; position: relative; }

  .tl-item::before {
    content: '';
    position: absolute;
    top: 18px; right: 50%; left: -50%;
    height: 2px;
    background: var(--border);
    z-index: 0;
  }

  .tl-item:first-child::before { display: none; }

  .tl-dot {
    width: 36px; height: 36px;
    background: var(--blue); color: white;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 900;
    margin: 0 auto 10px;
    position: relative; z-index: 1;
  }

  .tl-title { font-size: 12px; font-weight: 700; color: var(--steel); margin-bottom: 3px; }
  .tl-dur { font-size: 10.5px; color: var(--silver); }

  /* ===== REQUIREMENTS ===== */
  .req-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin-bottom: 32px; }

  .req-item {
    background: var(--light); border: 1px solid var(--border);
    padding: 11px 14px; border-radius: 2px;
    font-size: 12px; color: #374151;
    display: flex; align-items: center; gap: 8px;
  }

  .req-item::before { content: '◆'; color: var(--blue); font-size: 8px; flex-shrink: 0; }

  /* ===== NOTE ===== */
  .note-box {
    background: #EFF6FF; border: 1px solid #BFDBFE;
    border-right: 4px solid var(--blue);
    padding: 14px 18px; border-radius: 2px;
    font-size: 12.5px; color: #1e3a8a;
    margin-bottom: 24px; line-height: 1.8;
  }

  /* ===== NEXT STEPS ===== */
  .steps { display: flex; gap: 0; margin-bottom: 32px; }

  .step {
    flex: 1; text-align: center; padding: 20px 12px;
    border: 1px solid var(--border); border-left: none;
  }

  .step:first-child { border-left: 1px solid var(--border); border-radius: 0 2px 2px 0; }
  .step:last-child { border-radius: 2px 0 0 2px; }

  .step .s-num {
    width: 32px; height: 32px;
    background: var(--steel); color: white; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 900; margin: 0 auto 10px;
  }

  .step .s-title { font-size: 12px; font-weight: 700; color: var(--steel); margin-bottom: 4px; }
  .step .s-sub { font-size: 10.5px; color: var(--silver); }

  /* ===== FOOTER ===== */
  .page-footer {
    background: var(--steel);
    padding: 16px 52px;
    display: flex; justify-content: space-between; align-items: center;
    border-top: 2px solid var(--blue);
  }

  .page-footer span { font-size: 11px; color: rgba(255,255,255,0.35); }
  .footer-contact { font-size: 11px; color: rgba(255,255,255,0.45); text-align: left; }
  .page-num { font-size: 11px; color: rgba(255,255,255,0.25); }
</style>
</head>
